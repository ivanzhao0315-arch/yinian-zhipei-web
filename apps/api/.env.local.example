PORT=5175
HOST=127.0.0.1
DATABASE_PATH=./.data/dev.db

# sqlite: 本地 SQLite；mysql_snapshot: 将 SQLite 快照持久化到云托管 MySQL。
STORAGE_DRIVER=sqlite
MYSQL_ADDRESS=
MYSQL_USERNAME=
MYSQL_PASSWORD=
MYSQL_DATABASE=yinian_zhipei
MYSQL_SNAPSHOT_ID=primary

# 线上运营后台账号。设置 ADMIN_PASSWORD 后，演示密码 admin123 会失效。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_DISPLAY_NAME=运营管理员
ADMIN_SESSION_SECRET=
ADMIN_SESSION_TTL_SECONDS=43200

# 本地先用 mock；真实联调改成 live
WECHAT_PAY_MODE=mock

# 可以先真实登录、支付保持 mock
WECHAT_LOGIN_MODE=live

# 一个商户号绑定两个小程序时填写两个 AppID，英文逗号分隔
WECHAT_PAY_APPIDS=

# 多小程序 AppSecret，格式：appid1:secret1,appid2:secret2
# 只放在服务端本地文件，不能提交到仓库，不能写到小程序前端。
WECHAT_MINI_APP_SECRETS=

WECHAT_PAY_MCH_ID=
WECHAT_PAY_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_API_V3_KEY=

# 真实支付必须是公网 HTTPS 地址
WECHAT_PAY_NOTIFY_URL=

# 小程序订阅消息。mock 会只记录通知日志；live 会调用微信 subscribeMessage.send。
WECHAT_NOTIFY_MODE=mock
WECHAT_NOTIFY_MINIPROGRAM_STATE=developer
WECHAT_NOTIFY_TEMPLATE_ORDER_CREATED=
WECHAT_NOTIFY_TEMPLATE_ORDER_CONFIRMED=
WECHAT_NOTIFY_TEMPLATE_PAYMENT_PAID=
WECHAT_NOTIFY_TEMPLATE_FAMILY_ASSIGNED=
WECHAT_NOTIFY_TEMPLATE_ESCORT_ASSIGNED=
WECHAT_NOTIFY_TEMPLATE_PROGRESS_UPDATED=
WECHAT_NOTIFY_TEMPLATE_EXCEPTION_CREATED=
